{
  "name": "mcp_js",
  "version": "1.0.0",
  "type": "module",
  "main": "build/src/index.js",
  "scripts": {
    "build": "tsc",
   "dev": "cross-env NODE_ENV=dev ts-node build/src/index.js", 
  "start": "cross-env NODE_ENV=prod node build/src/index.js",
    "test": "cross-env NODE_ENV=test vitest run",
    "test:watch": "cross-env NODE_ENV=test vitest",
    "test:integration": "cross-env NODE_ENV=test vitest run --config vitest.integration.config.ts",
    "coverage": "cross-env NODE_ENV=test vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "xmlrpc": "^1.3.2",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.3",
    "@types/xmlrpc": "^1.3.10",
    "@vitest/coverage-v8": "^4.0.17",
    "cross-env": "^10.1.0",
    "supertest": "^7.2.2",
    "typescript": "^5.7.2",
    "vitest": "^4.0.17"
  }
}
